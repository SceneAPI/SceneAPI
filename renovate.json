{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(deps)",
    ":timezone(UTC)"
  ],
  "schedule": ["before 7am on monday"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",

  "enabledManagers": ["pip_requirements", "github-actions", "dockerfile"],

  "packageRules": [
    {
      "description": "GH Actions: group minor/patch into a single PR per week.",
      "matchManagers": ["github-actions"],
      "groupName": "gha-minor-patch",
      "matchUpdateTypes": ["minor", "patch"]
    }
  ],

  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  }
}
