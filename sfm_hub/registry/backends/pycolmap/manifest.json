  "config_schemas": [
    "colmap.*"
  ],
  "artifact_contracts": [
    "colmap.database",
    "colmap.sparse_model"
  ],
  "licenses": [
    {
      "name": "Apache-2.0"
    }
  ],
  "upstream_projects": [
    {
      "name": "pycolmap",
      "url": "https://github.com/colmap/pycolmap",
      "license": "BSD-3-Clause"
    },
    {
      "name": "COLMAP",
      "url": "https://github.com/colmap/colmap",
      "license": "BSD-3-Clause"
    }
  ],
  "compatibility": {
    "sfmapi": ">=0.0.1",
    "python": ">=3.12,<3.13",
    "os": [
      "windows",
      "linux",
      "macos"
    ],
    "tool_versions": {
