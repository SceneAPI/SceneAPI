{
  "schema_version": 1,
  "plugin_id": "realityscan_cli",
  "display_name": "RealityScan CLI",
  "description": "Backend plugin for installed RealityScan or RealityCapture command-line tools.",
  "package_name": "sceneapi-map",
  "github_url": "https://github.com/SceneAPI/SceneMap.git",
  "entry_points": [
    "sceneapi_map.realityscan.plugin:plugin"
  ],
  "providers": [
    {
      "provider_id": "realityscan_cli",
      "display_name": "RealityScan CLI",
      "capabilities": [],
      "backend_actions": [
        "realityscan.*"
      ],
      "priority_hint": 50
    }
  ],
  "runtime_modes": {
    "uv": {
      "source": "git",
      "url": "https://github.com/SceneAPI/SceneMap.git",
      "ref": "main",
      "package": "sceneapi-map"
    },
    "external_tool": {
      "executable_names": [
        "RealityScan.exe",
        "RealityCapture.exe"
      ],
      "env_vars": [
        "SFMAPI_RC_EXECUTABLE",
        "SFMAPI_REALITYCAPTURE_EXECUTABLE",
        "SFMAPI_REALITYSCAN_EXECUTABLE",
        "REALITYSCAN_EXE",
        "REALITYCAPTURE_EXE"
      ],
      "version_args": [
        "-version"
      ]
    }
  },
  "capabilities": [],
  "backend_actions": [
    "realityscan.*"
  ],
  "config_schemas": [],
  "artifact_contracts": [
    "realityscan.registration",
    "realityscan.sparse_point_cloud"
  ],
  "licenses": [
    {
      "name": "Apache-2.0"
    }
  ],
  "upstream_projects": [
    {
      "name": "RealityScan",
      "url": "https://www.capturingreality.com/realityscan",
      "license": "Proprietary"
    }
  ],
  "compatibility": {
    "sfmapi": ">=0.0.1",
    "python": ">=3.12,<3.13",
    "os": [
      "windows"
    ],
    "tool_versions": {
      "RealityScan": "current",
      "RealityCapture": "current"
    }
  },
  "conformance": {
    "status": "not_run",
    "suite": "sfmapi-bench"
  },
  "trust_tier": "official"
}
