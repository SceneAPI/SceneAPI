{
  "plugin_id": "colmap_native",
  "display_name": "Native COLMAP backends",
  "description": "COLMAP backend collection with CLI, pycolmap, native C++, and in-memory provider variants.",
  "package_name": "sfmapi-colmap",
  "github_url": "https://github.com/SFMAPI/sfmapi_colmap.git",
  "entry_points": ["sfmapi_colmap.plugin:plugin"],
  "providers": [
    {
      "provider_id": "colmap_cli",
      "display_name": "COLMAP CLI",
      "capabilities": [
        "ba.standard",
        "export.colmap_bin",
        "export.colmap_text",
        "export.nvm",
        "export.ply",
        "features.extract.sift",
        "georegister.gps",
        "georegister.sim3",
        "image.undistort",
        "index.vocab_tree",
        "map.global",
        "map.hierarchical",
        "map.incremental",
        "matchers.nn-mutual",
        "matchers.nn-ratio",
        "matches.verify",
        "pairs.exhaustive",
        "pairs.explicit",
        "pairs.from_poses",
        "pairs.sequential",
        "pairs.spatial",
        "pairs.vocabtree",
        "pgo.optimize",
        "pose_priors.mapping",
        "recon.merge",
        "relocalize.images",
        "rigs.configure",
        "triangulate.retri"
      ],
      "backend_actions": ["colmap.*"],
      "priority_hint": 25
    },
    {
      "provider_id": "colmap_pycolmap",
      "display_name": "pycolmap",
      "capabilities": [
        "backend.actions",
        "ba.standard",
        "export.colmap_bin",
        "export.colmap_text",
        "export.nvm",
        "export.ply",
        "features.extract.sift",
        "geometry.two_view",
        "georegister.gps",
        "georegister.sim3",
        "image.undistort",
        "index.vocab_tree",
        "map.global",
        "map.hierarchical",
        "map.incremental",
        "matchers.nn-mutual",
        "matchers.nn-ratio",
        "matches.verify",
        "pairs.exhaustive",
        "pairs.explicit",
        "pairs.from_poses",
        "pairs.sequential",
        "pairs.spatial",
        "pairs.vocabtree",
        "pgo.optimize",
        "pose_priors.mapping",
        "recon.merge",
        "relocalize.images",
        "rigs.configure",
        "triangulate.retri"
      ],
      "backend_actions": ["colmap.*"],
      "priority_hint": 35
    },
    {
      "provider_id": "colmap_cpp_native",
      "display_name": "COLMAP C++ native",
      "capabilities": [
        "ba.standard",
        "export.colmap_bin",
        "export.colmap_text",
        "export.nvm",
        "export.ply",
        "features.extract.sift",
        "georegister.gps",
        "georegister.sim3",
        "image.undistort",
        "index.vocab_tree",
        "map.global",
        "map.hierarchical",
        "map.incremental",
        "matchers.nn-mutual",
        "matchers.nn-ratio",
        "matches.verify",
        "pairs.exhaustive",
        "pairs.explicit",
        "pairs.from_poses",
        "pairs.sequential",
        "pairs.spatial",
        "pairs.vocabtree",
        "pgo.optimize",
        "pose_priors.mapping",
        "recon.merge",
        "relocalize.images",
        "rigs.configure",
        "triangulate.retri"
      ],
      "backend_actions": ["colmap.*"],
      "priority_hint": 40
    },
    {
      "provider_id": "colmap_cpp_inmemory",
      "display_name": "COLMAP C++ in-memory",
      "capabilities": [
        "compute.in_memory",
        "matchers.nn-mutual",
        "matches.verify",
        "pairs.exhaustive",
        "pairs.explicit",
        "pairs.sequential"
      ],
      "backend_actions": [],
      "priority_hint": 45
    }
  ],
  "runtime_modes": {
    "uv": {
      "source": "git",
      "url": "https://github.com/SFMAPI/sfmapi_colmap.git",
      "ref": "main",
      "package": "sfmapi-colmap"
    },
    "docker": null,
    "external_tool": {
      "executable_names": ["colmap", "colmap.exe"],
      "env_vars": ["SFMAPI_COLMAP_EXECUTABLE", "COLMAP_EXE", "SFMAPI_COLMAP_EXE"],
      "version_args": ["help"]
    }
  },
  "capabilities": [
    "backend.actions",
    "ba.standard",
    "compute.in_memory",
    "export.colmap_bin",
    "export.colmap_text",
    "export.nvm",
    "export.ply",
    "features.extract.sift",
    "geometry.two_view",
    "georegister.gps",
    "georegister.sim3",
    "image.undistort",
    "index.vocab_tree",
    "map.global",
    "map.hierarchical",
    "map.incremental",
    "matchers.nn-mutual",
    "matchers.nn-ratio",
    "matches.verify",
    "pairs.exhaustive",
    "pairs.explicit",
    "pairs.from_poses",
    "pairs.sequential",
    "pairs.spatial",
    "pairs.vocabtree",
    "pgo.optimize",
    "pose_priors.mapping",
    "recon.merge",
    "relocalize.images",
    "rigs.configure",
    "triangulate.retri"
  ],
  "backend_actions": ["colmap.*"],
  "config_schemas": ["colmap.*"],
  "artifact_contracts": ["colmap.database", "colmap.sparse_model"],
  "licenses": [{"name": "Apache-2.0"}],
  "upstream_projects": [
    {"name": "COLMAP", "url": "https://github.com/colmap/colmap", "license": "BSD-3-Clause"}
  ],
  "compatibility": {
    "sfmapi": ">=0.0.1",
    "python": ">=3.12,<3.13",
    "os": ["windows", "linux"],
    "cuda": "optional",
    "tool_versions": {"colmap": ">=4.1"}
  },
  "conformance": {"status": "not_run", "suite": "sfmapi-bench"},
  "trust_tier": "official"
}
