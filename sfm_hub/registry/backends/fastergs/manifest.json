{
  "schema_version": 1,
  "plugin_id": "fastergs",
  "display_name": "Faster-GS",
  "description": "3D Gaussian Splatting plugin for NeRFICG Faster-GS training, inference, and PLY export through the sfmapi radiance-field contract.",
  "package_name": "sfmapi-radiance",
  "github_url": "https://github.com/SFMAPI/sfmapi_radiance.git",
  "entry_points": [
    "sfmapi_radiance.providers.fastergs:plugin"
  ],
  "providers": [
    {
      "provider_id": "fastergs",
      "display_name": "Faster-GS",
      "capabilities": [
        "radiance.train",
        "radiance.evaluate",
        "radiance.metrics.psnr",
        "radiance.metrics.ssim",
        "radiance.metrics.lpips"
      ],
      "backend_actions": [
        "fastergs.*"
      ],
      "priority_hint": 78
    }
  ],
  "runtime_modes": {
    "uv": {
      "source": "git",
      "url": "https://github.com/SFMAPI/sfmapi_radiance.git",
      "ref": "main",
      "package": "sfmapi-radiance"
    },
    "docker": {
      "image": null,
      "build_context": "https://github.com/SFMAPI/sfmapi_radiance.git"
    },
    "container_service": {
      "protocol": "sfmapi-plugin-http-v1",
      "protocol_version": "1.0",
      "service": {
        "default_url": "http://127.0.0.1:8093",
        "url_env": "SFMAPI_FASTERGS_SERVICE_URL"
      },
      "image": {
        "build": {
          "source": "git",
          "context": "https://github.com/SFMAPI/sfmapi_radiance.git",
          "dockerfile": "docker/fastergs.Dockerfile",
          "ref": "main",
          "args": {
            "TORCH_DEVICE": "cuda",
            "TORCH_INDEX_URL": "https://download.pytorch.org/whl/cu128",
            "TORCH_PACKAGES": "torch torchvision torchaudio",
            "SFMAPI_FASTERGS_REF": "main"
          }
        }
      },
      "object_store": {
        "url_env": "SFMAPI_PLUGIN_OBJECT_STORE_URL",
        "input_prefix": "fastergs/input/",
        "output_prefix": "fastergs/output/"
      },
      "cache": {
        "policy": "read_write",
        "scope": "plugin",
        "path": "/sfmapi/cache"
      },
      "provenance": {
        "image_digest_required": false,
        "source_revision": "main"
      },
      "healthcheck": {
        "path": "/healthz",
        "timeout_seconds": 5
      },
      "execution": {
        "path": "/execute",
        "timeout_seconds": 86400,
        "mounts": {
          "input_path": "/sfmapi/input",
          "output_path": "/sfmapi/output",
          "work_path": "/sfmapi/work",
          "log_path": "/sfmapi/logs"
        },
        "gpu": "required",
        "env": [
          "TORCH_HOME",
          "TORCH_DEVICE",
          "CUDA_VISIBLE_DEVICES",
          "NVIDIA_VISIBLE_DEVICES",
          "NVIDIA_DRIVER_CAPABILITIES"
        ],
        "secrets": [],
        "retry": {
          "max_attempts": 1,
          "backoff_seconds": 0
        },
        "shutdown_timeout_seconds": 30,
        "log_collection": "both",
        "artifact_collection": true
      }
    },
    "external_tool": null
  },
  "capabilities": [
    "radiance.train",
    "radiance.evaluate",
    "radiance.metrics.psnr",
    "radiance.metrics.ssim",
    "radiance.metrics.lpips"
  ],
  "backend_actions": [
    "fastergs.*"
  ],
  "config_schemas": [
    "radiance.train",
    "fastergs.inference",
    "fastergs.export_ply",
    "fastergs.evaluate"
  ],
  "artifact_contracts": [
    "sfmapi.radiance.snapshot.v1",
    "sfmapi.radiance.variant.ply.v1",
    "sfmapi.radiance.metrics.v1"
  ],
  "licenses": [
    {
      "name": "Apache-2.0"
    }
  ],
  "upstream_projects": [
    {
      "name": "Faster Gaussian Splatting",
      "url": "https://github.com/nerficg-project/faster-gaussian-splatting",
      "license": null
    }
  ],
  "compatibility": {
    "sfmapi": ">=0.0.1",
    "python": ">=3.12,<3.13",
    "os": [
      "windows",
      "linux"
    ],
    "cuda": "required",
    "torch": {
      "policy": "required",
      "device": "cuda",
      "index_url": "https://download.pytorch.org/whl/cu128",
      "packages": [
        "torch",
        "torchvision",
        "torchaudio"
      ],
      "install_env": {
        "TORCH_DEVICE": "cuda",
        "TORCH_INDEX_URL": "https://download.pytorch.org/whl/cu128",
        "TORCH_PACKAGES": "torch torchvision torchaudio"
      }
    }
  },
  "conformance": {
    "status": "not_run",
    "suite": "sfmapi-bench"
  },
  "trust_tier": "community"
}
