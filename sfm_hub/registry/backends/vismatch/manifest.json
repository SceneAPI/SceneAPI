{
  "schema_version": 1,
  "plugin_id": "vismatch",
  "display_name": "Vismatch",
  "description": "Backend plugin for Vismatch pairwise image matching models. The plugin writes COLMAP keypoints/matches for downstream sfmapi verification and mapping; individual model licenses remain upstream model-specific.",
  "package_name": "scenematch[engine]",
  "github_url": "https://github.com/SceneAPI/SceneMatch.git",
  "entry_points": [
    "scenematch.vismatch.plugin:plugin"
  ],
  "providers": [
    {
      "provider_id": "vismatch",
      "display_name": "Vismatch",
      "capabilities": [
        "matchers.lightglue",
        "matchers.loftr",
        "matchers.nn-mutual",
        "pairs.exhaustive",
        "pairs.explicit",
        "pairs.sequential"
      ],
      "backend_actions": [
        "vismatch.*"
      ],
      "priority_hint": 35
    }
  ],
  "runtime_modes": {
    "uv": {
      "source": "git",
      "url": "https://github.com/SceneAPI/SceneMatch.git",
      "ref": "main",
      "package": "scenematch[engine]"
    },
    "docker": {
      "image": null,
      "build_context": "https://github.com/SceneAPI/SceneMatch.git"
    },
    "container_service": {
      "protocol": "sfmapi-plugin-http-v1",
      "protocol_version": "1.0",
      "service": {
        "default_url": "http://127.0.0.1:8097",
        "url_env": "SFMAPI_VISMATCH_SERVICE_URL"
      },
      "image": {
        "build": {
          "source": "git",
          "context": "https://github.com/SceneAPI/SceneMatch.git",
          "dockerfile": "Dockerfile",
          "ref": "main",
          "args": {
            "SFMAPI_REF": "main",
            "TORCH_DEVICE": "cuda",
            "TORCH_INDEX_URL": "https://download.pytorch.org/whl/cu128",
            "TORCH_CPU_INDEX_URL": "https://download.pytorch.org/whl/cpu",
            "TORCH_PACKAGES": "torch torchvision torchaudio",
            "VISMATCH_DEVICE": "cuda"
          }
        }
      },
      "object_store": {
        "url_env": "SFMAPI_PLUGIN_OBJECT_STORE_URL",
        "input_prefix": "vismatch/input/",
        "output_prefix": "vismatch/output/"
      },
      "cache": {
        "policy": "read_write",
        "scope": "plugin",
        "path": "/sfmapi/cache"
      },
      "provenance": {
        "image_digest_required": false,
        "source_revision": "main"
      },
      "healthcheck": {
        "path": "/healthz",
        "timeout_seconds": 5
      },
      "execution": {
        "path": "/execute",
        "timeout_seconds": 3600,
        "mounts": {
          "input_path": "/sfmapi/input",
          "output_path": "/sfmapi/output",
          "work_path": "/sfmapi/work",
          "log_path": "/sfmapi/logs"
        },
        "gpu": "optional",
        "env": [
          "HF_HOME",
          "TORCH_HOME",
          "TORCH_DEVICE",
          "VISMATCH_DEVICE"
        ],
        "secrets": [
          "HF_TOKEN"
        ],
        "retry": {
          "max_attempts": 2,
          "backoff_seconds": 0
        },
        "shutdown_timeout_seconds": 10,
        "log_collection": "both",
        "artifact_collection": true
      }
    }
  },
  "capabilities": [
    "matchers.lightglue",
    "matchers.loftr",
    "matchers.nn-mutual",
    "pairs.exhaustive",
    "pairs.explicit",
    "pairs.sequential"
  ],
  "backend_actions": [
    "vismatch.*"
  ],
  "config_schemas": [
    "vismatch.matcher",
    "vismatch.pairs"
  ],
  "artifact_contracts": [
    "vismatch.matches.coordinates",
    "vismatch.matches.database",
    "vismatch.matches.database_pairs"
  ],
  "licenses": [
    {
      "name": "Apache-2.0"
    }
  ],
  "upstream_projects": [
    {
      "name": "Vismatch",
      "url": "https://github.com/gmberton/vismatch",
      "license": "BSD-3-Clause"
    }
  ],
  "compatibility": {
    "sfmapi": ">=0.0.1",
    "python": ">=3.12,<3.13",
    "os": [
      "windows",
      "linux"
    ],
    "cuda": "recommended",
    "torch": {
      "policy": "recommended",
      "device": "cuda",
      "index_url": "https://download.pytorch.org/whl/cu128",
      "cpu_index_url": "https://download.pytorch.org/whl/cpu",
      "packages": [
        "torch",
        "torchvision",
        "torchaudio"
      ],
      "install_env": {
        "TORCH_DEVICE": "cuda",
        "TORCH_INDEX_URL": "https://download.pytorch.org/whl/cu128",
        "TORCH_CPU_INDEX_URL": "https://download.pytorch.org/whl/cpu",
        "TORCH_PACKAGES": "torch torchvision torchaudio"
      }
    }
  },
  "conformance": {
    "status": "not_run",
    "suite": "sfmapi-bench"
  },
  "trust_tier": "community"
}
