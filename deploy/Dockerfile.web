# sfmapi web container — minimal, no GPU, no pycolmap.
#
# This image runs `sfmapi.server.main:app` under uvicorn. It does NOT include
# pycolmap, torch, or any heavy ML deps; those live in the worker.

FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && pip install --upgrade pip uv

COPY pyproject.toml /app/pyproject.toml
COPY README.md /app/README.md
COPY sfmapi /app/sfmapi
COPY sfm_hub /app/sfm_hub
# Deprecated one-release `app` compatibility shim (removed in 0.1.0).
COPY app /app/app
COPY alembic /app/alembic
COPY alembic.ini /app/alembic.ini

# Install only the runtime deps (skip [seg] and [sfm] extras).
RUN uv pip install --system --no-cache .

RUN useradd -r -u 10001 -g root sfmapi \
 && mkdir -p /workspaces && chown -R sfmapi:root /workspaces

USER sfmapi
EXPOSE 8080

HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -fsS http://127.0.0.1:8080/healthz || exit 1

# Run migrations on startup, then launch uvicorn.
CMD ["sh", "-c", "alembic upgrade head && uvicorn sfmapi.server.main:app --host 0.0.0.0 --port 8080 --log-level info"]
