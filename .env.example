# sfmapi env vars (prefix: SFMAPI_)
#
# Defaults below give you a fully standalone install: SQLite file +
# filesystem blob store + in-process worker. No Docker, no Redis, no
# Postgres needed. Multi-instance / GPU-fleet deployments override
# the queue + db backends below.

SFMAPI_ENV=dev

# --- Database ---------------------------------------------------------------
# SQLite file beside the working dir. Survives restarts; no external
# server. Postgres works with the same schema — uncomment the second
# line to point at a managed cluster.
SFMAPI_DB_URL=sqlite+aiosqlite:///./sfmapi.db
# SFMAPI_DB_URL=postgresql+psycopg://sfm:sfm@localhost:5432/sfmapi

# --- Queue ------------------------------------------------------------------
# `inline` runs every task in the same process as the API (no Redis,
# no separate worker). `arq` is the multi-process backend that uses
# Redis below. Standalone default = inline.
SFMAPI_QUEUE_BACKEND=inline
# Only consulted when SFMAPI_QUEUE_BACKEND=arq.
# SFMAPI_REDIS_URL=redis://localhost:6379/0

# --- Storage ----------------------------------------------------------------
# `fs` writes blobs to the filesystem under SFMAPI_BLOB_ROOT.
# `s3` and `memory` are also available; see sfmapi/server/storage/blobs.py.
SFMAPI_BLOB_BACKEND=fs
SFMAPI_WORKSPACE_ROOT=./workspaces
SFMAPI_BLOB_ROOT=./workspaces/_blobs
SFMAPI_S3_CACHE_ROOT=./workspaces/_cache/s3

# --- Tenancy / auth ---------------------------------------------------------
SFMAPI_DEFAULT_TENANT=default
SFMAPI_AUTH_MODE=none

# --- Backend selection ------------------------------------------------------
# sfmapi ships only a no-op StubBackend; install a real backend
# package and set this to its registered name. Leave unset to require
# explicit `name=` arg in `get_backend()` calls (useful when running
# headless without any backend wired up).
# SFMAPI_BACKEND=stub

# Optional backend-runtime fingerprint, exposed in /v1/version for
# cache-key derivation. Backend packages typically populate this
# from their own build artifacts; sfmapi just forwards the string.
# SFMAPI_RUNTIME_VERSION_ID=unknown

# --- Ephemeral mode ---------------------------------------------------------
# When true: in-memory SQLite + InMemoryBlobStore + InlineQueue +
# tempdir workspace, all wiped on shutdown. Auto-registers the stub
# backend. Single-process only — do not enable on multi-instance
# deploys. Great for demos and smoke tests.
# SFMAPI_EPHEMERAL=true

# --- MCP --------------------------------------------------------------------
# Optional FastMCP adapter. The default is off. Use `local` to mount
# MCP into the FastAPI app at SFMAPI_MCP_MOUNT_PATH; use the standalone
# `sfmapi mcp` / `sfmapi-mcp` commands for stdio or local HTTP. Treat
# API-mounted MCP as a local or trusted-network convenience. Install with:
#   uv sync --extra mcp
# For API + MCP in one local process:
#   uv run sfmapi serve --mcp local --reload
# For stdio or standalone local HTTP:
#   uv run sfmapi mcp
#   uv run sfmapi mcp --transport http --port 9000
# Direct entrypoint kept for existing agent launchers:
#   uv run sfmapi-mcp
#   uv run sfmapi-mcp --transport http --port 9000
# SFMAPI_MCP_MODE=local
# Backward-compatible API-mount alias still supported:
# SFMAPI_MCP_ENABLED=true
# SFMAPI_MCP_MOUNT_PATH=/mcp
# Required when SFMAPI_AUTH_MODE=api_key so MCP reads are bound to one tenant.
# SFMAPI_MCP_TENANT_ID=default

SFMAPI_LOG_LEVEL=INFO
