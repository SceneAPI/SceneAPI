# sfmapi env vars (prefix: SFMAPI_)

SFMAPI_ENV=dev
SFMAPI_DB_URL=sqlite+aiosqlite:///./sfmapi.db
# SFMAPI_DB_URL=postgresql+psycopg://sfm:sfm@localhost:5432/sfmapi

SFMAPI_REDIS_URL=redis://localhost:6379/0

SFMAPI_WORKSPACE_ROOT=./workspaces
SFMAPI_BLOB_ROOT=./workspaces/_blobs
SFMAPI_S3_CACHE_ROOT=./workspaces/_cache/s3

SFMAPI_DEFAULT_TENANT=default
SFMAPI_AUTH_MODE=none

# Backend selection. sfmapi ships only a no-op StubBackend; install
# a real backend package and set this to its registered name. Leave
# unset to require explicit `name=` arg in `get_backend()` calls
# (useful when running headless without any backend wired up).
# SFMAPI_BACKEND=stub

# Optional backend-runtime fingerprints, exposed in /v1/version for
# cache-key derivation. Backend packages typically populate these
# from their own build artifacts; sfmapi just forwards the strings.
# SFMAPI_RUNTIME_VERSION_ID=unknown

SFMAPI_LOG_LEVEL=INFO
